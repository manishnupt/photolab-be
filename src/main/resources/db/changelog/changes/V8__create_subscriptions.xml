<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1" author="dev">
        <createTable tableName="subscription">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="agency_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="plan" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="events_used" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="events_limit" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="storage_limit_mb" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="renews_at" type="TIMESTAMP WITHOUT TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="dev">
        <addForeignKeyConstraint
            baseTableName="subscription"
            baseColumnNames="agency_id"
            constraintName="fk_subscription_agency"
            referencedTableName="agency"
            referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="3" author="dev">
        <createIndex indexName="idx_subscription_agency_id" tableName="subscription">
            <column name="agency_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
