<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1" author="dev">
        <createTable tableName="selfie_search">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="s3_key_selfie" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="matched_tag_id" type="UUID"/>
            <column name="match_score" type="DOUBLE PRECISION"/>
            <column name="searched_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="dev">
        <addForeignKeyConstraint
            baseTableName="selfie_search"
            baseColumnNames="event_id"
            constraintName="fk_selfie_search_event"
            referencedTableName="events"
            referencedColumnNames="id"/>
        <addForeignKeyConstraint
            baseTableName="selfie_search"
            baseColumnNames="matched_tag_id"
            constraintName="fk_selfie_search_face_tag"
            referencedTableName="face_tag"
            referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="3" author="dev">
        <createIndex indexName="idx_selfie_search_event_id" tableName="selfie_search">
            <column name="event_id"/>
        </createIndex>
        <createIndex indexName="idx_selfie_search_matched_tag_id" tableName="selfie_search">
            <column name="matched_tag_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
